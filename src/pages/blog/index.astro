---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Manual testing articles and guides.">
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="font-display font-bold text-3xl text-slate-900 mb-2">Blog</h1>
    <p class="text-slate-600 mb-10">Guides and articles about manual testing.</p>
    <ul class="space-y-6">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`} class="block p-4 rounded-xl border border-slate-200 bg-white hover:border-accent hover:shadow-md transition-all">
            <h2 class="font-display font-semibold text-lg text-slate-900">{post.data.title}</h2>
            <p class="text-slate-600 text-sm mt-1">{post.data.description}</p>
            <time class="text-slate-400 text-xs mt-2 block" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { dateStyle: 'medium' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
