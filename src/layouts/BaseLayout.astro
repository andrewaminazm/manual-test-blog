---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Learn manual testing from the ground up. Clear guides for anyone who wants to become a software tester.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | Manual Test Blog</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 font-sans antialiased">
    <header class="border-b border-slate-200 bg-white/80 backdrop-blur sticky top-0 z-10">
      <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-display font-semibold text-lg text-slate-800 hover:text-accent transition-colors">
          Manual Test Blog
        </a>
        <a href="/blog" class="text-slate-600 hover:text-accent transition-colors">Blog</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-slate-200 mt-16 py-8 text-center text-slate-500 text-sm">
      <p>Manual Test Blog — Clear guides for everyone who wants to become a tester.</p>
    </footer>
  </body>
</html>
